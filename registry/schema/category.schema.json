{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devforgekit.dev/schema/category.schema.json",
  "title": "DevForgeKit registry category",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "label", "description"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    }
  }
}
