{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devforgekit.dev/schema/collection.schema.json",
  "title": "DevForgeKit registry collection manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "description", "components"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
