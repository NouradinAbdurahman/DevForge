{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devforgekit.dev/schema/package.schema.json",
  "title": "DevForgeKit registry package manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "description", "category", "platforms"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["macos", "linux", "windows"]
      }
    },
    "variants": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/variant" }
    },
    "install": { "$ref": "#/$defs/installStep" },
    "platformInstall": {
      "type": "object",
      "description": "Platform-specific install steps. Keys are platform IDs (macos, linux, windows). The installer picks the entry matching the current platform; falls back to the top-level install field if no match.",
      "properties": {
        "macos": { "$ref": "#/$defs/installStep" },
        "linux": { "$ref": "#/$defs/installStep" },
        "windows": { "$ref": "#/$defs/installStep" }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "conflicts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validate": { "type": "string" },
    "repair": { "type": "string" },
    "update": { "type": "string" },
    "uninstall": { "$ref": "#/$defs/installStep" },
    "post_install": {
      "type": "array",
      "items": { "type": "string" }
    },
    "homepage": { "type": "string" },
    "repository": { "type": "string" },
    "license": { "type": "string" },
    "maintainer": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "documentation": { "type": "string" },
    "architectures": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["intel", "apple-silicon", "linux", "x64", "arm64"]
      }
    },
    "stability": {
      "type": "string",
      "enum": ["stable", "beta", "deprecated"]
    },
    "lastVerified": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "ciVerified": { "type": "boolean" },
    "versionCommand": {
      "type": "string",
      "description": "Shell command whose output contains this component's installed version (Compatibility Engine - core/compatibility/versions.js). Optional: falls back to parsing `validate`'s output, then to 'unknown' - never guessed beyond that."
    },
    "recommendedAlternatives": {
      "type": "array",
      "description": "Names of other registry packages that serve a similar purpose and may be worth considering (Compatibility Engine repair suggestions).",
      "items": { "type": "string" }
    }
  },
  "oneOf": [
    { "required": ["install"] },
    { "required": ["variants"] }
  ],
  "$defs": {
    "installStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["brew-formula", "brew-cask", "npm", "pip", "cargo", "mise", "shell", "apt", "dnf", "pacman", "winget", "choco", "scoop"]
        },
        "id": { "type": "string" },
        "command": { "type": "string" },
        "tap": { "type": "string" }
      }
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "install"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "install": { "$ref": "#/$defs/installStep" },
        "platformInstall": {
          "type": "object",
          "description": "Platform-specific install steps for this variant.",
          "properties": {
            "macos": { "$ref": "#/$defs/installStep" },
            "linux": { "$ref": "#/$defs/installStep" },
            "windows": { "$ref": "#/$defs/installStep" }
          },
          "additionalProperties": false
        }
      }
    }
  }
}
