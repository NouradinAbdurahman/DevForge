#!/usr/bin/env bash
# Unified CLI for DevForgeKit - dispatches to bootstrap.sh/scripts/*.sh so
# you don't have to remember individual script names. bootstrap.sh symlinks
# this file onto PATH (see install_global_command in scripts/common.sh), so
# it works identically as `./devforgekit` (from the repo) or a plain
# `devforgekit` (from anywhere, once installed).
#
# Layer 2 delegation (see docs/PlatformArchitecture.md): every command
# except install/bootstrap is handed off to the Node CLI under cli/ once
# it has been set up by bootstrap.sh (ensure_cli_dependencies in
# scripts/common.sh). Until then - or on a machine where Node setup
# failed/was skipped - this file falls back to the original bash
# dispatch table below verbatim, so behavior never regresses. install/
# bootstrap never delegate to Node: bootstrap.sh must work before Node
# exists at all (mise installs Node, not the other way around).
#
# Usage: devforgekit <command> [args...]
set -Eeuo pipefail

# Resolve symlinks to find the real repo location: when installed as a
# global command (a symlink in the Homebrew prefix's bin, see
# install_global_command in scripts/common.sh), `${BASH_SOURCE[0]}`
# resolves to the symlink's own path, and a plain `dirname` would point at
# the symlink's directory (e.g. /opt/homebrew/bin) instead of this repo.
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    SOURCE_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
SELF="$(basename "${BASH_SOURCE[0]}")"

usage() {
    cat <<EOF
Usage: $SELF <command> [args...]

Run with no arguments to open the interactive terminal dashboard
(requires the Node CLI; falls back to this help text otherwise -
see docs/TUI.md).

Commands:
  install [options]     Full provision (forwards to bootstrap.sh)
  bootstrap [options]   Alias for install
                        options: -y|--yes, --skip-services, --dry-run,
                                 --profile <name>, --minimal, --full
  update                Upgrade the managed toolchain, restart services
  self-update           Update DevForgeKit itself (git pull, deps, config, plugins)
  snapshot <action>     Environment Snapshot & Restore (create, restore, list, inspect, verify, diff)
  benchmark <action>    Benchmark Engine (quick, full, standard, compare, history, export)
  repair <action>       Intelligent Repair Engine (scan, plan, run, verify, rollback, history)
  package <action>      Package Intelligence & Analytics (analyze, info, tree, orphan, duplicates)
  graph <action>        Development Environment Graph (open, search, impact, path, stats, export)
  backup                Capture live config into the repo, commit+push
  restore               Restore dotfiles/editors from the repo
  check                 Fast PASS/WARNING/FAIL health check
  doctor [--fix]        Deep diagnostics + health score
  validate              Validate this repo's own scripts/configs
  inventory              Generate machine inventory reports
  report                 Generate a system report
  services <action>      start|stop|restart|status for local services
  clean                  Reclaim disk space
  release <bump>         patch|minor|major version release
  preferences <action>   backup|restore|status for macOS UI preferences
  profile <action>       list|show|use - manage install profiles
  uninstall              Not yet implemented
  help                   Show this message

The following commands require the Node CLI (installed by bootstrap.sh -
see docs/PlatformArchitecture.md); they no-op with an "Unknown command"
error until then:
  config <action>        get|set|list - manage DevForgeKit configuration
  component <action>     list|info|install|validate|repair|uninstall
  plugin <action>         list|info|run - manage DevForgeKit plugins
  recipe <action>          list|show|install|create|import|search - one-command environment workflows
  new <stack> [name]       generate a complete project (Flutter, Next.js, Express, ...)
  dashboard | ui           open the interactive terminal dashboard (docs/TUI.md)

Examples:
  $SELF install --profile flutter
  $SELF doctor --fix
  $SELF profile list
  $SELF services status
  $SELF component install
  $SELF recipe install ai-engineer
  $SELF new nextjs my-app
EOF
}

# cli_available - true when the Node CLI has been set up (Node itself is
# on PATH and cli/'s npm dependencies are installed). Checked fresh on
# every invocation rather than cached, since either can change between
# runs (e.g. right after `./bootstrap.sh` finishes).
cli_available() {
    command -v node >/dev/null 2>&1 && [[ -d "$SCRIPT_DIR/cli/node_modules" ]]
}

# No arguments: hand off to the Node CLI with *no* command - it opens
# the interactive dashboard (v1.2.3, docs/TUI.md) on a capable TTY and
# falls back to --help output otherwise (bin/devforgekit.js decides).
# Without the Node CLI, the original usage text keeps working unchanged.
if [[ $# -eq 0 ]]; then
    if cli_available; then
        exec node "$SCRIPT_DIR/cli/bin/devforgekit.js"
    fi
    usage
    exit 1
fi

cmd="$1"
shift

case "$cmd" in
    install|bootstrap) exec "$SCRIPT_DIR/bootstrap.sh" "$@" ;;
esac

if cli_available; then
    exec node "$SCRIPT_DIR/cli/bin/devforgekit.js" "$cmd" "$@"
fi

# Legacy fallback: the Node CLI isn't set up yet (fresh clone, before the
# first bootstrap run, or a machine that skipped/failed Node setup) -
# dispatch directly to the original bash scripts so every command still
# works exactly as it did before Layer 2 existed.
case "$cmd" in
    update) exec "$SCRIPT_DIR/scripts/update.sh" "$@" ;;
    backup) exec "$SCRIPT_DIR/scripts/backup.sh" "$@" ;;
    restore) exec "$SCRIPT_DIR/scripts/restore.sh" "$@" ;;
    check) exec "$SCRIPT_DIR/scripts/check.sh" "$@" ;;
    doctor) exec "$SCRIPT_DIR/scripts/doctor.sh" "$@" ;;
    validate) exec "$SCRIPT_DIR/scripts/validate.sh" "$@" ;;
    inventory) exec "$SCRIPT_DIR/scripts/inventory.sh" "$@" ;;
    report) exec "$SCRIPT_DIR/scripts/report.sh" "$@" ;;
    services) exec "$SCRIPT_DIR/scripts/services.sh" "$@" ;;
    clean|cleanup) exec "$SCRIPT_DIR/scripts/cleanup.sh" "$@" ;;
    release) exec "$SCRIPT_DIR/scripts/release.sh" "$@" ;;
    preferences|prefs) exec "$SCRIPT_DIR/scripts/preferences.sh" "$@" ;;
    profile) exec "$SCRIPT_DIR/scripts/profile.sh" "$@" ;;
    uninstall)
        echo "'$SELF uninstall' is not implemented yet." >&2
        echo "For now, review and remove packages manually, e.g.:" >&2
        echo "  brew bundle cleanup --file=Brewfile        # lists what brew bundle would remove" >&2
        echo "  brew bundle cleanup --file=Brewfile --force # actually removes it" >&2
        exit 1
        ;;
    -h|--help|help) usage ;;
    *)
        echo "Unknown command: $cmd" >&2
        echo >&2
        usage >&2
        exit 1
        ;;
esac
