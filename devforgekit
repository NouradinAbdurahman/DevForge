#!/usr/bin/env bash
# Unified CLI for DevForgeKit - dispatches to bootstrap.sh/scripts/*.sh so
# you don't have to remember individual script names. bootstrap.sh symlinks
# this file onto PATH (see install_global_command in scripts/common.sh), so
# it works identically as `./devforgekit` (from the repo) or a plain
# `devforgekit` (from anywhere, once installed).
#
# Layer 2 delegation (see docs/PlatformArchitecture.md): every command
# except install/bootstrap is handed off to the Node CLI under cli/ once
# it has been set up by bootstrap.sh (ensure_cli_dependencies in
# scripts/common.sh). Until then - or on a machine where Node setup
# failed/was skipped - this file falls back to the original bash
# dispatch table below verbatim, so behavior never regresses. install/
# bootstrap never delegate to Node: bootstrap.sh must work before Node
# exists at all (mise installs Node, not the other way around).
#
# Usage: devforgekit <command> [args...]
set -Eeuo pipefail

# Resolve symlinks to find the real repo location: when installed as a
# global command (a symlink in the Homebrew prefix's bin, see
# install_global_command in scripts/common.sh), `${BASH_SOURCE[0]}`
# resolves to the symlink's own path, and a plain `dirname` would point at
# the symlink's directory (e.g. /opt/homebrew/bin) instead of this repo.
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    SOURCE_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
SELF="$(basename "${BASH_SOURCE[0]}")"

usage() {
    cat <<EOF
Usage: $SELF <command> [args...]

Run with no arguments to open the interactive terminal dashboard
(requires the Node CLI; falls back to this help text otherwise -
see docs/TUI.md).

Commands:
  install [options]     Full provision (forwards to bootstrap.sh)
  bootstrap [options]   Alias for install
                        options: -y|--yes, --skip-services, --dry-run,
                                 --profile <name>, --minimal, --full
  update                Upgrade the managed toolchain, restart services
  self-update           Update DevForgeKit itself (git pull, deps, config, plugins)
  snapshot <action>     Environment Snapshot & Restore (create, restore, list, inspect, verify, diff)
  benchmark <action>    Benchmark Engine (quick, full, standard, compare, history, export)
  repair <action>       Intelligent Repair Engine (scan, plan, run, verify, rollback, history)
  package <action>      Package Intelligence & Analytics (analyze, info, tree, orphan, duplicates)
  graph <action>        Development Environment Graph (open, search, impact, path, stats, export)
  backup                Capture live config into the repo, commit+push
  restore               Restore dotfiles/editors from the repo
  check                 Fast PASS/WARNING/FAIL health check
  doctor [--fix]        Deep diagnostics + health score
  validate              Validate this repo's own scripts/configs
  inventory              Generate machine inventory reports
  report                 Generate a system report
  services <action>      start|stop|restart|status for local services
  clean                  Reclaim disk space
  release <bump>         patch|minor|major version release
  preferences <action>   backup|restore|status for macOS UI preferences
  profile <action>       list|show|use - manage install profiles
  uninstall [flags]      Remove what DevForgeKit installed (--all/--packages/--config/--vscode/--cursor/--services; see uninstall --help)
  rc-validate [flags]    Distribution Verification & RC Validation - the final gate before a release (see RELEASE.md)
  help                   Show this message

The following commands require the Node CLI (installed by bootstrap.sh -
see docs/PlatformArchitecture.md); they no-op with an "Unknown command"
error until then:
  config <action>        get|set|list - manage DevForgeKit configuration
  component <action>     list|info|install|validate|repair|uninstall
  plugin <action>         list|info|run - manage DevForgeKit plugins
  recipe <action>          list|show|install|create|import|search - one-command environment workflows
  new <stack> [name]       generate a complete project (Flutter, Next.js, Express, ...)
  dashboard | ui           open the interactive terminal dashboard (docs/TUI.md)
  completion <action>       install|uninstall|status|doctor - shell completions (zsh/bash/fish) for npm installs

Examples:
  $SELF install --profile flutter
  $SELF doctor --fix
  $SELF profile list
  $SELF services status
  $SELF component install
  $SELF recipe install ai-engineer
  $SELF new nextjs my-app
EOF
}

# CLI_FALLBACK_ROOT - a user-writable mirror of this repo, used only when
# "$SCRIPT_DIR/cli" itself isn't writable (see self_heal_cli_deps below).
# Namespaced by the real install location (not just a fixed path) so
# multiple installs (e.g. a Homebrew copy and an npm copy) on the same
# machine never collide with each other's fallback.
CLI_FALLBACK_ROOT="${XDG_CACHE_HOME:-$HOME/.cache}/devforgekit/cli-fallback/$(printf '%s' "$SCRIPT_DIR" | cksum | cut -d' ' -f1)"

# cli_available - true when the Node CLI has been set up: Node itself is
# on PATH, and cli/'s npm dependencies are installed either in place
# ("$SCRIPT_DIR/cli/node_modules", the normal/preferred case) or in the
# fallback mirror (see self_heal_cli_deps) and that mirror isn't stale.
# Checked fresh on every invocation rather than cached, since any of
# this can change between runs (e.g. right after `./bootstrap.sh`
# finishes, or after `npm update -g devforgekit`).
cli_available() {
    command -v node >/dev/null 2>&1 || return 1
    [[ -d "$SCRIPT_DIR/cli/node_modules" ]] && return 0
    [[ -d "$CLI_FALLBACK_ROOT/cli/node_modules" ]] || return 1
    [[ "$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null)" == "$(cat "$CLI_FALLBACK_ROOT/.mirrored-version" 2>/dev/null)" ]]
}

# cli_entrypoint - which devforgekit.js to actually run: the in-place one
# if its node_modules exists, otherwise the fallback mirror's copy. Only
# meaningful after cli_available/self_heal_cli_deps has returned success.
cli_entrypoint() {
    if [[ -d "$SCRIPT_DIR/cli/node_modules" ]]; then
        printf '%s\n' "$SCRIPT_DIR/cli/bin/devforgekit.js"
    else
        printf '%s\n' "$CLI_FALLBACK_ROOT/cli/bin/devforgekit.js"
    fi
}

# self_heal_cli_deps - a one-time-per-failure attempt to install cli/'s
# npm dependencies just-in-time, for an npm-installed copy whose
# postinstall script didn't run. Modern npm (11.x+) added an
# allow-scripts approval gate that can silently skip postinstall by
# default even with ignore-scripts=false - confirmed live, not assumed -
# so `npm install -g devforgekit` alone cannot be relied on to always
# populate cli/node_modules. This mirrors ensure_cli_dependencies() in
# scripts/common.sh, quiet on success, and writes a marker on failure so
# a real, ongoing problem (no network, no npm) doesn't retry - and
# therefore add multi-second latency - on every single command.
#
# Two attempts, in order:
#   1. In place, directly in "$SCRIPT_DIR/cli" - fast, and shared by
#      every future invocation with zero ongoing overhead. Works
#      whenever that directory is writable (a repo clone, the Homebrew
#      Cellar, or an npm global prefix the user already owns).
#   2. A user-writable mirror at CLI_FALLBACK_ROOT - needed when (1)'s
#      directory is root-owned, almost always because the package was
#      installed with `sudo npm install -g` (confirmed live: reproduced
#      in a clean Ubuntu 22.04 + npm 11.18 container - see
#      docs/NpmGlobalInstallRootCause.md). Real copies of cli/bin and cli/src
#      (not symlinks) so Node's module resolver, which resolves a
#      symlinked module back to its real path before searching for
#      node_modules, can't walk straight back to the still-missing,
#      still-unwritable original cli/node_modules. Every *other*
#      top-level entry (registry/, docs/, profiles/, scripts/, VERSION,
#      etc. - anything core/paths.js's repoRoot()-relative lookups might
#      ever reach) is symlinked instead: those are read with plain
#      fs calls, which follow symlinks correctly, and symlinking keeps
#      the mirror automatically current with the real install with no
#      separate sync step. A .mirrored-version marker (compared against
#      the real VERSION file by cli_available) invalidates the mirror
#      after `npm update -g devforgekit` ships new cli/src, so the
#      fallback can't silently keep running stale code forever.
self_heal_cli_deps() {
    command -v node >/dev/null 2>&1 || return 1
    [[ -d "$SCRIPT_DIR/cli/node_modules" ]] && return 0
    [[ -f "$SCRIPT_DIR/cli/package.json" ]] || return 1
    command -v npm >/dev/null 2>&1 || return 1

    if [[ -d "$CLI_FALLBACK_ROOT/cli/node_modules" ]] \
        && [[ "$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null)" == "$(cat "$CLI_FALLBACK_ROOT/.mirrored-version" 2>/dev/null)" ]]; then
        return 0
    fi

    local marker="$SCRIPT_DIR/cli/.npm-install-failed"
    local fallback_marker="$CLI_FALLBACK_ROOT/.npm-install-failed"

    if [[ -w "$SCRIPT_DIR/cli" ]] && [[ ! -f "$marker" ]]; then
        echo "Setting up the DevForgeKit CLI (first run only)..." >&2
        if (cd "$SCRIPT_DIR/cli" && npm install --omit=dev --no-audit --no-fund >/dev/null 2>&1); then
            rm -f "$marker"
            return 0
        fi
        touch "$marker" 2>/dev/null || true
    fi

    [[ -f "$fallback_marker" ]] && return 1
    [[ -w "$SCRIPT_DIR/cli" ]] && return 1

    [[ -f "$marker" ]] || echo "Setting up the DevForgeKit CLI (first run only)..." >&2
    rm -rf "$CLI_FALLBACK_ROOT"
    mkdir -p "$CLI_FALLBACK_ROOT/cli" 2>/dev/null || return 1

    local entry
    for entry in "$SCRIPT_DIR"/*; do
        [[ "$(basename "$entry")" == "cli" ]] && continue
        ln -sfn "$entry" "$CLI_FALLBACK_ROOT/$(basename "$entry")" 2>/dev/null
    done
    cp -R "$SCRIPT_DIR/cli/bin" "$CLI_FALLBACK_ROOT/cli/bin" 2>/dev/null
    cp -R "$SCRIPT_DIR/cli/src" "$CLI_FALLBACK_ROOT/cli/src" 2>/dev/null
    cp "$SCRIPT_DIR/cli/package.json" "$CLI_FALLBACK_ROOT/cli/package.json" 2>/dev/null
    [[ -f "$SCRIPT_DIR/cli/package-lock.json" ]] && cp "$SCRIPT_DIR/cli/package-lock.json" "$CLI_FALLBACK_ROOT/cli/package-lock.json" 2>/dev/null

    if (cd "$CLI_FALLBACK_ROOT/cli" && npm install --omit=dev --no-audit --no-fund >/dev/null 2>&1); then
        cp "$SCRIPT_DIR/VERSION" "$CLI_FALLBACK_ROOT/.mirrored-version" 2>/dev/null || true
        rm -f "$fallback_marker"
        return 0
    fi

    touch "$fallback_marker" 2>/dev/null || true
    echo "Automatic setup failed." >&2
    echo "This usually means devforgekit was installed with 'sudo npm install -g'," >&2
    echo "which leaves \"$SCRIPT_DIR/cli\" owned by root. Fix with one of:" >&2
    echo "  sudo npm install --omit=dev --prefix \"$SCRIPT_DIR/cli\"" >&2
    echo "  sudo chown -R \"\$(id -un)\" \"$SCRIPT_DIR/cli\" && devforgekit" >&2
    return 1
}

# No arguments: hand off to the Node CLI with *no* command - it opens
# the interactive dashboard (v1.2.3, docs/TUI.md) on a capable TTY and
# falls back to --help output otherwise (bin/devforgekit.js decides).
# Without the Node CLI, the original usage text keeps working unchanged.
if [[ $# -eq 0 ]]; then
    if cli_available || self_heal_cli_deps; then
        exec node "$(cli_entrypoint)"
    fi
    usage
    exit 1
fi

cmd="$1"
shift

case "$cmd" in
    install|bootstrap) exec "$SCRIPT_DIR/bootstrap.sh" "$@" ;;
esac

if cli_available || self_heal_cli_deps; then
    exec node "$(cli_entrypoint)" "$cmd" "$@"
fi

# Legacy fallback: the Node CLI isn't set up yet (fresh clone, before the
# first bootstrap run, or a machine that skipped/failed Node setup) -
# dispatch directly to the original bash scripts so every command still
# works exactly as it did before Layer 2 existed.
case "$cmd" in
    update) exec "$SCRIPT_DIR/scripts/update.sh" "$@" ;;
    backup) exec "$SCRIPT_DIR/scripts/backup.sh" "$@" ;;
    restore) exec "$SCRIPT_DIR/scripts/restore.sh" "$@" ;;
    check) exec "$SCRIPT_DIR/scripts/check.sh" "$@" ;;
    doctor) exec "$SCRIPT_DIR/scripts/doctor.sh" "$@" ;;
    validate) exec "$SCRIPT_DIR/scripts/validate.sh" "$@" ;;
    inventory) exec "$SCRIPT_DIR/scripts/inventory.sh" "$@" ;;
    report) exec "$SCRIPT_DIR/scripts/report.sh" "$@" ;;
    services) exec "$SCRIPT_DIR/scripts/services.sh" "$@" ;;
    clean|cleanup) exec "$SCRIPT_DIR/scripts/cleanup.sh" "$@" ;;
    release) exec "$SCRIPT_DIR/scripts/release.sh" "$@" ;;
    preferences|prefs) exec "$SCRIPT_DIR/scripts/preferences.sh" "$@" ;;
    profile) exec "$SCRIPT_DIR/scripts/profile.sh" "$@" ;;
    uninstall) exec "$SCRIPT_DIR/scripts/uninstall.sh" "$@" ;;
    rc-validate) exec "$SCRIPT_DIR/scripts/rc-validate.sh" "$@" ;;
    -h|--help|help) usage ;;
    config|component|plugin|recipe|new|dashboard|ui|completion|completions)
        echo "'$SELF $cmd' requires the Node CLI, which isn't set up yet on this machine." >&2
        echo "Node was not found on PATH, or cli/node_modules is missing." >&2
        echo >&2
        echo "Fix:" >&2
        echo "  cd \"$SCRIPT_DIR/cli\" && npm install" >&2
        echo "or run bootstrap, which does this automatically:" >&2
        echo "  $SELF install" >&2
        exit 1
        ;;
    *)
        echo "Unknown command: $cmd" >&2
        echo >&2
        usage >&2
        exit 1
        ;;
esac
